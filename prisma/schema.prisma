generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//// ENUMS

enum UserRole {
  SUPERADMIN
  ADMIN
  MANAGER
  COUPE
  PRODUCTION
  QUALITE
  LOGISTIQUE
  CAISSIER
  RH
  COMPTABLE
}

enum OrderStatus {
  EN_ATTENTE
  EN_COURS
  TERMINE
  ANNULE
}

enum StepStatus {
  EN_ATTENTE
  EN_COURS
  TERMINE
  REJETE
}

enum Currency {
  USD
  CDF
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK
}

enum StockMoveType {
  IN
  OUT
  ADJUST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  RETARD
  CONGE
}

enum LeaveStatus {
  EN_ATTENTE
  APPROUVE
  REJETE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELED
}

enum ExpenseStatus {
  DRAFT
  VALIDATED
  PAID
  CANCELED
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum PresenceStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum NotificationType {
  MESSAGE
  ORDER_ASSIGNED
  ORDER_STATUS_CHANGED
  WORKFLOW_STEP_CHANGED
  PAYMENT_RECORDED
  STOCK_LOW
  SYSTEM
}

enum OrderFileType {
  PDF
  IMAGE
  WORD
  EXCEL
  OTHER
}

enum ProductionAssignmentStatus {
  EN_ATTENTE
  EN_COURS
  TERMINE
  BLOQUE
  ANNULE
}

enum ProductionPriority {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum CutPriority {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum CutAssignmentStatus {
  EN_ATTENTE
  EN_COURS
  TERMINE
  BLOQUE
  ANNULE
}

//// USERS + PERMISSIONS + PRESENCE

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true)

  permissions UserPermission[]
  activities  ActivityLog[]

  cutSteps        CutStep[]        @relation("CutStepResponsible")
  productionSteps ProductionStep[] @relation("ProductionStepResponsible")
  qualitySteps    QualityStep[]    @relation("QualityStepResponsible")
  deliverySteps   DeliveryStep[]   @relation("DeliveryStepResponsible")

  createdPayments Payment[]     @relation("PaymentCreatedBy")
  createdInvoices Invoice[]     @relation("InvoiceCreatedBy")
  createdExpenses Expense[]     @relation("ExpenseCreatedBy")
  createdLedger   LedgerEntry[] @relation("LedgerCreatedBy")

  stockMovesCreated StockMove[] @relation("StockMoveCreatedBy")

  leaveRequestsDecided LeaveRequest[] @relation("LeaveRequestDecidedBy")

  employee Employee?
  presence UserPresence?

  conversationsCreated Conversation[]
  conversationMembers  ConversationMember[]
  messagesSent         Message[]
  messageReceipts      MessageReceipt[]
  messageReactions     MessageReaction[]
  typingIndicators     ConversationTyping[]

  notifications Notification[]

  orderAttachmentsCreated OrderAttachment[]

  measurementsTaken OrderMeasurements[] @relation("MeasurementsTakenBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPresence {
  id         String         @id @default(cuid())
  userId     String         @unique
  status     PresenceStatus @default(OFFLINE)
  lastSeenAt DateTime?
  lastPingAt DateTime?
  device     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  label String

  users UserPermission[]
}

model UserPermission {
  id           String @id @default(cuid())
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

//// CUSTOMERS

model Customer {
  id       String  @id @default(cuid())
  fullName String
  type     String  @default("STANDARD")
  phone    String?
  email    String?
  address  String?
  note     String?

  orders   Order[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// ORDERS + PAYMENTS

model Order {
  id     String      @id @default(cuid())
  code   String      @unique
  status OrderStatus @default(EN_ATTENTE)

  currency      Currency @default(USD)
  fxRate        Float    @default(1)
  totalAmount   Float    @default(0)
  depositAmount Float    @default(0)
  discount      Float    @default(0)
  balanceAmount Float    @default(0)

  isLot       Boolean @default(false)
  lotLabel    String?
  lotQuantity Int     @default(1)

  itemType     String?
  category     String?
  fabricType   String?
  fabricColor  String?
  fabricMeters Float?

  description  String?
  measurements String?
  scanUrl      String?

  sentToCuttingAt   DateTime?
  cuttingReceivedAt DateTime?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  cut        CutStep?
  production ProductionStep?
  quality    QualityStep?
  delivery   DeliveryStep?

  payments Payment[]

  ledgerEntries LedgerEntry[] @relation("OrderLedgerEntries")
  invoiceItems  InvoiceItem[] @relation("OrderInvoiceItems")

  attachments       OrderAttachment[]
  coupeMeasurements OrderMeasurements?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount   Float
  currency Currency      @default(USD)
  method   PaymentMethod @default(CASH)
  note     String?
  paidAt   DateTime      @default(now())

  createdById String?
  createdBy   User?   @relation("PaymentCreatedBy", fields: [createdById], references: [id])

  ledgerEntry LedgerEntry?

  createdAt DateTime @default(now())
}

model OrderAttachment {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  title    String?
  fileName String?
  type     OrderFileType @default(OTHER)
  url      String
  mimeType String?
  fileSize Int?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model OrderMeasurements {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  dataJson String @default("{}")

  takenByDept String?

  takenById String?
  takenBy   User?   @relation("MeasurementsTakenBy", fields: [takenById], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

//// WORKFLOW

model CutStep {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status StepStatus @default(EN_ATTENTE)

  responsibleId String?
  responsible   User?   @relation("CutStepResponsible", fields: [responsibleId], references: [id])

  receivedAt DateTime?
  startedAt  DateTime?
  finishedAt DateTime?

  dueAt    DateTime?
  priority CutPriority @default(NORMALE)

  plannedQuantity   Int @default(0)
  completedQuantity Int @default(0)

  fabricChecked       Boolean @default(false)
  patternReady        Boolean @default(false)
  measurementsChecked Boolean @default(false)

  note String?

  assignments CutAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CutAssignment {
  id String @id @default(cuid())

  cutStepId String
  cutStep   CutStep @relation(fields: [cutStepId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  roleLabel String?

  assignedQuantity  Int @default(0)
  completedQuantity Int @default(0)

  status   CutAssignmentStatus @default(EN_ATTENTE)
  priority CutPriority         @default(NORMALE)

  assignedAt DateTime  @default(now())
  startAt    DateTime?
  endAt      DateTime?
  dueAt      DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cutStepId])
  @@index([employeeId])
}

model ProductionStep {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status StepStatus @default(EN_ATTENTE)

  responsibleId String?
  responsible   User?   @relation("ProductionStepResponsible", fields: [responsibleId], references: [id])

  startedAt  DateTime?
  finishedAt DateTime?
  dueAt      DateTime?
  priority   ProductionPriority @default(NORMALE)

  plannedQuantity   Int @default(0)
  completedQuantity Int @default(0)

  note String?

  assignments ProductionAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductionAssignment {
  id String @id @default(cuid())

  productionStepId String
  productionStep   ProductionStep @relation(fields: [productionStepId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  roleLabel String?

  assignedQuantity  Int @default(0)
  completedQuantity Int @default(0)

  status   ProductionAssignmentStatus @default(EN_ATTENTE)
  priority ProductionPriority         @default(NORMALE)

  assignedAt DateTime  @default(now())
  startAt    DateTime?
  endAt      DateTime?
  dueAt      DateTime?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productionStepId])
  @@index([employeeId])
}

model QualityStep {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status StepStatus @default(EN_ATTENTE)

  responsibleId String?
  responsible   User?   @relation("QualityStepResponsible", fields: [responsibleId], references: [id])

  checkedAt DateTime?
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryStep {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status StepStatus @default(EN_ATTENTE)

  responsibleId String?
  responsible   User?   @relation("DeliveryStepResponsible", fields: [responsibleId], references: [id])

  deliveredAt DateTime?
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// STOCK

model StockItem {
  id       String  @id @default(cuid())
  name     String
  category String?
  unit     String?
  quantity Float   @default(0)

  minQuantity Float @default(0)
  unitCost    Float @default(0)

  moves     StockMove[]
  purchases StockPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockMove {
  id     String    @id @default(cuid())
  itemId String
  item   StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  type     StockMoveType
  quantity Float
  note     String?
  movedAt  DateTime      @default(now())

  createdById String?
  createdBy   User?   @relation("StockMoveCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model StockPreset {
  id          String  @id @default(cuid())
  name        String  @unique
  category    String?
  unit        String?
  minQuantity Float   @default(0)
  unitCost    Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockSupplier {
  id      String  @id @default(cuid())
  name    String  @unique
  phone   String?
  email   String?
  address String?

  purchases StockPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockPurchase {
  id          String   @id @default(cuid())
  itemId      String
  supplierId  String?
  quantity    Float    @default(0)
  unitCost    Float    @default(0)
  currency    Currency @default(USD)
  purchasedAt DateTime @default(now())
  reference   String?

  item     StockItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier StockSupplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([itemId, purchasedAt])
  @@index([supplierId, purchasedAt])
}

//// ACTIVITY LOG

model ActivityLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action   String
  entity   String?
  entityId String?
  metaJson String?

  createdAt DateTime @default(now())
}

//// ACCOUNTING

model Account {
  id   String @id @default(cuid())
  code String @unique
  name String
  type String

  entries LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LedgerEntry {
  id       String   @id @default(cuid())
  date     DateTime @default(now())
  label    String
  debit    Float    @default(0)
  credit   Float    @default(0)
  currency Currency @default(USD)
  fxRate   Float    @default(1)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  orderId String?
  order   Order?  @relation("OrderLedgerEntries", fields: [orderId], references: [id])

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id])

  createdById String?
  createdBy   User?   @relation("LedgerCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model Invoice {
  id       String        @id @default(cuid())
  number   String        @unique
  status   InvoiceStatus @default(DRAFT)
  currency Currency      @default(USD)
  fxRate   Float         @default(1)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  items         InvoiceItem[]
  totalAmount   Float         @default(0)
  paidAmount    Float         @default(0)
  balanceAmount Float         @default(0)

  issuedAt DateTime?
  dueAt    DateTime?
  note     String?

  createdById String?
  createdBy   User?   @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  label     String
  quantity  Float  @default(1)
  unitPrice Float  @default(0)
  lineTotal Float  @default(0)

  orderId String?
  order   Order?  @relation("OrderInvoiceItems", fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

model Supplier {
  id      String  @id @default(cuid())
  name    String
  phone   String?
  email   String?
  address String?

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id     String        @id @default(cuid())
  number String        @unique
  status ExpenseStatus @default(DRAFT)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  label    String
  amount   Float    @default(0)
  currency Currency @default(USD)
  fxRate   Float    @default(1)

  paidAt      DateTime?
  note        String?
  documentUrl String?

  createdById String?
  createdBy   User?   @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// HR

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id       String  @id @default(cuid())
  fullName String
  phone    String?
  email    String?
  address  String?

  hireDate DateTime?
  status   String    @default("ACTIVE")

  baseSalary Float    @default(0)
  currency   Currency @default(USD)

  documentUrl String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  attendances           Attendance[]
  leaves                LeaveRequest[]
  payslips              Payslip[]
  productionAssignments ProductionAssignment[]
  cutAssignments        CutAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  photoUrl String?
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date   DateTime
  status AttendanceStatus @default(PRESENT)
  note   String?

  createdAt DateTime @default(now())

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  reason    String?
  status    LeaveStatus @default(EN_ATTENTE)

  decidedById String?
  decidedBy   User?   @relation("LeaveRequestDecidedBy", fields: [decidedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PayrollRun {
  id          String   @id @default(cuid())
  periodLabel String
  currency    Currency @default(USD)

  payslips Payslip[]

  createdAt DateTime @default(now())
}

model Payslip {
  id String @id @default(cuid())

  payrollRunId String?
  payrollRun   PayrollRun? @relation(fields: [payrollRunId], references: [id])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  baseSalary Float @default(0)
  bonus      Float @default(0)
  deductions Float @default(0)
  netSalary  Float @default(0)

  note        String?
  generatedAt DateTime @default(now())
}

//// INTERNAL CHAT

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType @default(DIRECT)
  title       String?
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id])

  members  ConversationMember[]
  messages Message[]
  typingIndicators ConversationTyping[]

  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ConversationMember {
  id             String  @id @default(cuid())
  conversationId String
  userId         String
  role           String?
  muted          Boolean @default(false)

  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  parentId       String?
  type           MessageType @default(TEXT)

  text     String?
  fileUrl  String?
  fileName String?
  fileSize Int?

  entity   String?
  entityId String?

  status MessageStatus @default(SENT)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  parent       Message?     @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Message[]    @relation("MessageThread")

  receipts  MessageReceipt[]
  reactions MessageReaction[]

  createdAt DateTime @default(now())

  @@index([conversationId, parentId, createdAt])
}

model MessageReceipt {
  id        String @id @default(cuid())
  messageId String
  userId    String

  deliveredAt DateTime?
  readAt      DateTime?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model MessageReaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([userId])
}

model ConversationTyping {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([conversationId, userId])
  @@index([conversationId, updatedAt])
  @@index([userId])
}

//// NOTIFICATIONS

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType

  title String
  body  String?

  entity   String?
  entityId String?
  url      String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
